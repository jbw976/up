{
    "mcpServers": {
        "kubectl-ai": {
            "command": "kubectl-ai",
            "args": [
                "--mcp-server"
            ]
        },
        "upbound-marketplace": {
            "command": "docker",
            "args": [
                "run",
                "--name",
                "mcp-marketplace",
                "--rm",
                "-i",
                "-v",
                "{{ .UpConfigDir }}/:/mcp/.up:ro",
                "{{ .MarketPlaceMCP }}"
            ]
        }
    }
}
