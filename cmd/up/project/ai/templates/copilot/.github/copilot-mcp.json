{
  "mcpServers": {
    "upbound-marketplace": {
      "type": "local",
      "command": "docker",
      "args": [
        "run",
        "--name",
        "mcp-marketplace",
        "--rm",
        "-i",
        "-v",
        "{{ .UpConfigDir }}/:/mcp/.up:ro",
        "{{ .MarketPlaceMCP }}"
      ],
      "tools": [
        "*"
      ]
    }
  }
}