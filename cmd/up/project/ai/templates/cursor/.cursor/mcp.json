{
    "mcpServers": {
        "upbound-marketplace": {
            "command": "docker",
            "args": [
                "run",
                "--name",
                "mcp-marketplace",
                "--rm",
                "-i",
                "-v",
                "{{ .UpConfigDir }}/:/mcp/.up:ro",
                "{{ .MarketPlaceMCP }}"
            ]
        }
    }
}
